# LLM API Key
OPENAI_API_KEY=your_openai_api_key_here

# Embedding model (runs locally, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=medassist_docs

# RAG settings
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K_RESULTS=5

# Server
HOST=0.0.0.0
PORT=8000

# Admin secret for /ingest and /upload endpoints
# ADMIN_SECRET=your_secret_here
